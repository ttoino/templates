{
    "name": "{{ name }}",
    "version": "0.0.1",
    "description": "{{ description }}",
    "type": "module",
{% if type == 'library' %}    "license": "GPL-3.0-or-later",
    "files": [
        "dist",
        "!dist/**/*.test.*",
        "!dist/**/*.spec.*"
    ],
    "sideEffects": [
        "**/*.css"
    ],
    "svelte": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "svelte": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "peerDependencies": {
        "svelte": "^5.0.0"
    },
{% endif %}    "scripts": {
{% if type == 'worker' %}        "dev": "wrangler dev",
        "check": "tsc --noEmit",
        "build": "tsc",
{% else %}        "dev": "vite dev",
        "build": "vite build{% if type == 'library' %} && pnpm run prepack{% endif %}",
        "preview": "pnpm run build && wrangler dev",
{% if type == 'library' %}        "prepare": "svelte-kit sync || echo ''",
        "prepack": "svelte-kit sync && svelte-package && publint",
{% endif %}        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
{% endif %}        "lint": "eslint .",
        "lint:fix": "eslint --fix .",
        "format": "prettier --check .",
        "format:fix": "prettier --write .",
        "gen": "pnpm run gen:cf-types",
        "gen:cf-types": "wrangler types{% if type in ['sveltekit', 'library'] %} src/worker-configuration.d.ts{% endif %}"{% if tests %},
        "test": "vitest"{% endif %}
    },
{% if type == 'worker' %}    "dependencies": {
        "hono": "^4.12.0"
    },
{% endif %}    "devDependencies": {
{% if tests and type == 'worker' %}        "@cloudflare/vitest-pool-workers": "^0.16.9",
{% endif %}        "@eslint/compat": "^2.1.0",
        "@eslint/js": "^10.0.1",{% if type in ['sveltekit', 'library'] %}
        "@sveltejs/adapter-cloudflare": "^7.2.8",{% endif %}{% if type in ['sveltekit', 'library'] %}
        "@sveltejs/kit": "^2.59.0",{% endif %}{% if type == 'library' %}
        "@sveltejs/package": "^2.5.7",{% endif %}{% if type in ['sveltekit', 'library'] %}
        "@sveltejs/vite-plugin-svelte": "^7.0.0",{% endif %}{% if tailwind %}
        "@tailwindcss/vite": "^4.2.4",{% endif %}
        "@types/node": "^22.0.0",{% if browser_tests %}
        "@vitest/browser-playwright": "^4.1.5",{% endif %}{% if svelte_m3c %}
        "bits-ui": "^2.18.0",{% endif %}
        "eslint": "^10.4.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-perfectionist": "^5.9.0",{% if type in ['sveltekit', 'library'] %}
        "eslint-plugin-svelte": "^3.5.1",{% endif %}
        "globals": "^17.6.0",{% if browser_tests %}
        "playwright": "^1.59.1",{% endif %}
        "prettier": "^3.8.3",{% if type in ['sveltekit', 'library'] %}
        "prettier-plugin-svelte": "^3.5.1",{% endif %}{% if tailwind %}
        "prettier-plugin-tailwindcss": "^0.8.0",{% endif %}{% if type == 'library' %}
        "publint": "^0.3.18",{% endif %}{% if type in ['sveltekit', 'library'] %}
        "svelte": "^5.55.5",{% endif %}{% if type in ['sveltekit', 'library'] %}
        "svelte-check": "^4.4.7",{% endif %}{% if svelte_m3c %}
        "svelte-m3c": "^0.0.5",{% endif %}{% if svelte_m3c %}
        "tailwind-merge": "^3.5.0",{% endif %}{% if svelte_m3c %}
        "tailwind-variants": "^3.2.2",{% endif %}{% if tailwind %}
        "tailwindcss": "^4.2.4",{% endif %}
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.4",{% if type in ['sveltekit', 'library'] %}
        "vite": "^8.0.10",{% endif %}{% if tests %}
        "vitest": "^4.1.7",{% endif %}
        "wrangler": "^4.94.0"
    },
    "packageManager": "pnpm@11.2.2+sha512.36e6621fad506178936455e70247b8808ef4ec25797a9f437a93281a020484e2607f6a469a22e982987c3dbb8866e3071514ab10a4a1749e06edcd1ec118436f"
}
